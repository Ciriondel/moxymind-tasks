        {
          "listen": "test",
          "script": {
            "exec": [
              "// Assert HTTP code 201 \r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "// Assert ID and timestamp of createdAt \r",
              "pm.test(\"Response has ID and createdAt\", function () {\r",
              "    pm.expect(response).to.have.property('id'); \r",
              "    pm.expect(response).to.have.property('createdAt'); \r",
              "});\r",
              "\r",
              "// Assert Response time < variable (limit = 400ms)\r",
              "const limit = 400; \r",
              "pm.test(\"Response time is less than \" + limit + \"ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(limit); \r",
              "});\r",
              "\r",
              "// Bonus: Verify response schema \r",
              "const schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "        \"name\": { \"type\": \"string\" },\r",
              "        \"job\": { \"type\": \"string\" },\r",
              "        \"id\": { \"type\": \"string\" },\r",
              "        \"createdAt\": { \"type\": \"string\" }\r",
              "    },\r",
              "    \"required\": [\"name\", \"job\", \"id\", \"createdAt\"]\r",
              "};\r",
              "\r",
              "pm.test(\"Response schema is valid\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});"
            ],
