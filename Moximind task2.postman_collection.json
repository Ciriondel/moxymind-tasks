    {
      "name": "List Users",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Assert \"total\" exists\r",
              "pm.test(\"Response contains total\", function () {\r",
              "    pm.expect(jsonData).to.have.property('total');\r",
              "});\r",
              "\r",
              "// Assert \"last_name\" for first and second user \r",
              "pm.test(\"Validate last_name for first two users\", function () {\r",
              "    pm.expect(jsonData.data[0].last_name).to.not.be.undefined; \r",
              "    pm.expect(jsonData.data[1].last_name).to.not.be.undefined; \r",
              "    console.log(\"User 1 Last Name: \" + jsonData.data[0].last_name);\r",
              "});\r",
              "\r",
              "// Count users and compare to \"total\" \r",
              "pm.test(\"User count in data matches total\", function () {\r",
              "    const userCount = jsonData.data.length;\r",
              "    pm.expect(userCount).to.be.at.most(jsonData.total); \r",
              "});\r",
              "\r",
              "// Bonus: Create assertions for data types [\r",
              "pm.test(\"Data types are valid\", function () {\r",
              "    pm.expect(jsonData.page).to.be.a('number');\r",
              "    pm.expect(jsonData.data).to.be.an('array'); \r",
              "    pm.expect(jsonData.data[0].first_name).to.be.a('string'); \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
